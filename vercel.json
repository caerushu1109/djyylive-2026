{
  "cleanUrls": false,
  "redirects": [
    {
      "source": "/",
      "destination": "/zh/index.html",
      "permanent": false
    },
    {
      "source": "/zh",
      "destination": "/zh/index.html",
      "permanent": false
    },
    {
      "source": "/en",
      "destination": "/en/index.html",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
